.planning/
node_modules/
dist/
apps/*/dist/
packages/*/dist/
*.tsbuildinfo
.vite/
# Rust build output and wasm-pack artifacts are build-only — never committed.
# (`crates/*/target` covers solver and any future crate; `pkg/` is the
# wasm-pack output, rebuilt by scripts/ensure-wasm.mjs.)
crates/*/target/
crates/*/pkg/
test/
.test_data/
.playwright-mcp/
.env
.env.local
.claude/
# Python virtualenvs (any variant: .venv, .venv-headless, ...) — never committed.
.venv*/
python/src/calab/*.so
python/docs/_build/
python/docs/autoapi/
